TELEGRAM_BOT_TOKEN=your_token_here

# For adhahi.dz the base is https://adhahi.dz
QUOTA_API_BASE_URL=https://adhahi.dz
QUOTA_API_KEY=

CHECK_INTERVAL_SECONDS=300

# When `available=true` is detected, re-fetch the quotas this many extra times
# before notifying. This helps reduce false positives from transient/cached API responses.
CONFIRM_FETCHES=2

# Delay between confirmation re-fetches (seconds)
CONFIRM_DELAY_SECONDS=1

# sqlite file path inside container (mounted volume)
DATABASE_PATH=/data/subscriptions.db

LOG_LEVEL=INFO
HTTP_TIMEOUT_SECONDS=10

# 2Captcha API key for reliable CAPTCHA solving (https://2captcha.com)
# When set, the bot uses 2captcha instead of local OCR (ddddocr).
# Leave empty to fall back to local OCR.
TWO_CAPTCHA_API_KEY=

# Telegram user ID for the bot admin. Grants access to /adminammar panel.
# Find your ID by messaging @userinfobot on Telegram.
ADMIN_TELEGRAM_ID=your_telegram_id_here

# Proxy Settings (Optional)
# Databay residential proxy details (http://user:pass@host:port)
# Set USE_PROXY=true in .env to enable proxying for auto-registration.
USE_PROXY=false
PROXY_USER=
PROXY_PASS=
PROXY_HOST=gw.databay.co
PROXY_PORT=8888

# Global limit for simultaneous connections during auto-registration.
# Ensures the server isn't overloaded and avoids session hijacking flags.
# Can be adjusted on-the-fly from the Admin Panel.
MAX_CONCURRENT_SESSIONS=50
